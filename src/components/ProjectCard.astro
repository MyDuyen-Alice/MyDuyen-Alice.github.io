---
import type { Lang } from '../i18n/ui';
import { t, pathFor } from '../i18n/ui';
import type { Project } from '../data/projects';

interface Props {
  project: Project;
  lang: Lang;
}

const { project, lang } = Astro.props;

const statusClass = {
  planned: 'bg-slate-100 text-slate-600 ring-1 ring-slate-200',
  inProgress: 'bg-amber-50 text-amber-700 ring-1 ring-amber-200',
  completed: 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-200',
}[project.status];

const statusLabel = t(lang, `projects.status.${project.status}` as Parameters<typeof t>[1]);
const caseHref = pathFor(lang, `projects/${project.slug}`);
---

<article class="group rounded-xl border border-slate-200 bg-white p-6 shadow-sm hover:shadow-md hover:border-indigo-200 transition-all">
  <div class="flex items-start justify-between gap-3 mb-3">
    <h3 class="text-xl font-semibold text-slate-900 group-hover:text-indigo-600 transition-colors">
      <a href={caseHref}>{project.title[lang]}</a>
    </h3>
    <span class={`text-xs px-2 py-1 rounded-full whitespace-nowrap ${statusClass}`}>
      {statusLabel}
    </span>
  </div>
  <p class="text-slate-600 text-sm mb-4">{project.tagline[lang]}</p>
  <div class="flex flex-wrap gap-1.5 mb-4">
    {
      project.techStack.slice(0, 6).map((tech) => (
        <span class="text-xs px-2 py-0.5 rounded bg-slate-100 text-slate-700">
          {tech}
        </span>
      ))
    }
  </div>
  <div class="flex items-center gap-4 text-sm">
    <a
      href={caseHref}
      class="text-indigo-600 hover:text-indigo-500 font-medium transition-colors"
    >
      {t(lang, 'projects.viewCase')} →
    </a>
    {
      project.repoUrl && (
        <a
          href={project.repoUrl}
          target="_blank"
          rel="noopener"
          class="text-slate-500 hover:text-slate-900 transition-colors"
        >
          {t(lang, 'projects.viewRepo')} ↗
        </a>
      )
    }
  </div>
</article>
