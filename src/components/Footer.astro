---
import type { Lang } from '../i18n/ui';
import { t } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<footer class="border-t border-slate-800 mt-16">
  <div class="mx-auto max-w-5xl px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-slate-500">
    <p>{t(lang, 'footer.year')}</p>
    <p>{t(lang, 'footer.built')}</p>
    <div class="flex gap-4">
      <a
        href="https://github.com/"
        target="_blank"
        rel="noopener"
        class="hover:text-emerald-400 transition-colors"
        >GitHub</a
      >
      <a
        href="https://www.linkedin.com/"
        target="_blank"
        rel="noopener"
        class="hover:text-emerald-400 transition-colors"
        >LinkedIn</a
      >
      <a
        href="mailto:vongocminh0609@gmail.com"
        class="hover:text-emerald-400 transition-colors"
        >Email</a
      >
    </div>
  </div>
</footer>
