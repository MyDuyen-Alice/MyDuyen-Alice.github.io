---
interface Props {
  src: string;
  alt: string;
  caption?: string;
}

const { src, alt, caption } = Astro.props;
---

<figure class="not-prose my-6">
  <div class="rounded-lg border border-slate-200 bg-white p-2 shadow-sm overflow-hidden">
    <img src={src} alt={alt} loading="lazy" class="w-full h-auto rounded" />
  </div>
  {caption && (
    <figcaption class="mt-2 text-sm text-slate-500 text-center">
      {caption}
    </figcaption>
  )}
</figure>
