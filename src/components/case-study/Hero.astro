---
import KPIGrid from './KPIGrid.astro';

interface KPI {
  label: string;
  value: string;
  hint?: string;
}

interface Props {
  title: string;
  tagline: string;
  problem: string;
  outcome: string;
  techStack: string[];
  kpis: KPI[];
  status: 'planned' | 'inProgress' | 'completed';
  statusLabel: string;
  repoUrl?: string;
  demoUrl?: string;
}

const {
  title,
  tagline,
  problem,
  outcome,
  techStack,
  kpis,
  status,
  statusLabel,
  repoUrl,
  demoUrl,
} = Astro.props;

const statusClass = {
  planned: 'bg-slate-100 text-slate-600 ring-1 ring-slate-200',
  inProgress: 'bg-amber-50 text-amber-700 ring-1 ring-amber-200',
  completed: 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-200',
}[status];
---

<header class="pt-8 md:pt-12">
  <div class="flex items-start justify-between gap-4">
    <h1 class="text-3xl md:text-5xl font-bold text-slate-900 tracking-tight">
      {title}
    </h1>
    <span
      class={`text-xs px-2 py-1 rounded-full whitespace-nowrap ${statusClass}`}
    >
      {statusLabel}
    </span>
  </div>

  <p class="mt-4 text-lg text-slate-700 max-w-3xl">
    {tagline}
  </p>

  <div class="mt-8 grid gap-4 md:grid-cols-2">
    <div class="rounded-xl border border-rose-200 bg-rose-50/60 p-5">
      <p class="text-xs uppercase tracking-wider text-rose-700 font-medium mb-2">
        Vấn đề
      </p>
      <p class="text-slate-800 leading-relaxed">{problem}</p>
    </div>
    <div class="rounded-xl border border-emerald-200 bg-emerald-50/60 p-5">
      <p class="text-xs uppercase tracking-wider text-emerald-700 font-medium mb-2">
        Kết quả
      </p>
      <p class="text-slate-800 leading-relaxed">{outcome}</p>
    </div>
  </div>

  {kpis.length > 0 && <KPIGrid kpis={kpis} />}

  <div class="mt-6 flex flex-wrap items-center gap-3">
    {
      repoUrl && (
        <a
          href={repoUrl}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-1.5 bg-slate-900 hover:bg-slate-800 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors"
        >
          <span>GitHub</span>
          <span aria-hidden="true">↗</span>
        </a>
      )
    }
    {
      demoUrl && (
        <a
          href={demoUrl}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-1.5 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors"
        >
          <span>Live demo</span>
          <span aria-hidden="true">↗</span>
        </a>
      )
    }

    <div class="flex flex-wrap gap-1.5 ml-auto">
      {
        techStack.slice(0, 8).map((tech) => (
          <span class="text-xs px-2 py-1 rounded bg-slate-100 text-slate-700">
            {tech}
          </span>
        ))
      }
    </div>
  </div>

  <hr class="mt-10 border-slate-200" />
</header>
