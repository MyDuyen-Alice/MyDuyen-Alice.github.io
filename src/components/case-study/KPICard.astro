---
interface Props {
  label: string;
  value: string;
  hint?: string;
}

const { label, value, hint } = Astro.props;
---

<div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
  <p class="text-xs uppercase tracking-wider text-slate-500 font-medium">
    {label}
  </p>
  <p class="mt-2 text-3xl font-bold text-slate-900 tracking-tight tabular-nums">
    {value}
  </p>
  {hint && <p class="mt-1 text-xs text-slate-500">{hint}</p>}
</div>
