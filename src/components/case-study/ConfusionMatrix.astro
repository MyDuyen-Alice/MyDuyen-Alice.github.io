---
interface Props {
  tp: number;
  fp: number;
  fn: number;
  tn: number;
  positiveLabel?: string;
  negativeLabel?: string;
}

const {
  tp,
  fp,
  fn,
  tn,
  positiveLabel = 'Churn = Yes',
  negativeLabel = 'Churn = No',
} = Astro.props;

const total = tp + fp + fn + tn;
const fmt = (n: number) =>
  total ? `${((n / total) * 100).toFixed(1)}%` : '—';
---

<div class="not-prose my-6">
  <div class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
    <div class="grid grid-cols-[auto_1fr_1fr] gap-2 text-sm">
      <!-- Empty top-left + 2 predicted headers -->
      <div></div>
      <div class="text-center text-xs uppercase tracking-wider text-slate-500 font-medium pb-1">
        Predicted: {negativeLabel}
      </div>
      <div class="text-center text-xs uppercase tracking-wider text-slate-500 font-medium pb-1">
        Predicted: {positiveLabel}
      </div>

      <!-- Row 1: Actual negative -->
      <div class="self-center text-xs uppercase tracking-wider text-slate-500 font-medium [writing-mode:vertical-rl] rotate-180 py-2">
        Actual: {negativeLabel}
      </div>
      <div class="rounded-lg bg-emerald-50 ring-1 ring-emerald-200 p-4 text-center">
        <p class="text-xs text-emerald-700 font-medium">TN</p>
        <p class="text-2xl font-bold text-slate-900 tabular-nums">{tn}</p>
        <p class="text-xs text-slate-500 mt-0.5">{fmt(tn)}</p>
      </div>
      <div class="rounded-lg bg-rose-50 ring-1 ring-rose-200 p-4 text-center">
        <p class="text-xs text-rose-700 font-medium">FP</p>
        <p class="text-2xl font-bold text-slate-900 tabular-nums">{fp}</p>
        <p class="text-xs text-slate-500 mt-0.5">{fmt(fp)}</p>
      </div>

      <!-- Row 2: Actual positive -->
      <div class="self-center text-xs uppercase tracking-wider text-slate-500 font-medium [writing-mode:vertical-rl] rotate-180 py-2">
        Actual: {positiveLabel}
      </div>
      <div class="rounded-lg bg-rose-50 ring-1 ring-rose-200 p-4 text-center">
        <p class="text-xs text-rose-700 font-medium">FN</p>
        <p class="text-2xl font-bold text-slate-900 tabular-nums">{fn}</p>
        <p class="text-xs text-slate-500 mt-0.5">{fmt(fn)}</p>
      </div>
      <div class="rounded-lg bg-emerald-50 ring-1 ring-emerald-200 p-4 text-center">
        <p class="text-xs text-emerald-700 font-medium">TP</p>
        <p class="text-2xl font-bold text-slate-900 tabular-nums">{tp}</p>
        <p class="text-xs text-slate-500 mt-0.5">{fmt(tp)}</p>
      </div>
    </div>
  </div>
</div>
