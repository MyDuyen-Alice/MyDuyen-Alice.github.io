---
interface Tool {
  name: string;
  role: string;
  url?: string;
}

interface Props {
  tools: Tool[];
  title?: string;
}

const { tools, title } = Astro.props;
---

<div class="not-prose my-5">
  {
    title && (
      <p class="text-xs uppercase tracking-wider text-slate-500 font-semibold mb-2">
        {title}
      </p>
    )
  }
  <div class="grid gap-2 sm:grid-cols-2 lg:grid-cols-3">
    {
      tools.map((t) => (
        <div class="rounded-lg border border-slate-200 bg-white p-3 hover:border-indigo-200 transition-colors">
          <p class="font-mono text-sm font-semibold text-indigo-700">
            {t.url ? (
              <a href={t.url} target="_blank" rel="noopener" class="hover:underline">
                {t.name}
              </a>
            ) : (
              t.name
            )}
          </p>
          <p class="text-xs text-slate-600 mt-0.5 leading-snug">{t.role}</p>
        </div>
      ))
    }
  </div>
</div>
