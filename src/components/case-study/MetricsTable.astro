---
interface Row {
  cells: (string | number)[];
  best?: boolean;
}

interface Props {
  headers: string[];
  rows: Row[];
  caption?: string;
}

const { headers, rows, caption } = Astro.props;
---

<div class="not-prose my-6 overflow-x-auto rounded-lg border border-slate-200 bg-white shadow-sm">
  <table class="w-full text-sm">
    <thead class="bg-slate-50 border-b border-slate-200">
      <tr>
        {
          headers.map((h, i) => (
            <th
              class={`px-4 py-3 font-semibold text-slate-700 ${i === 0 ? 'text-left' : 'text-right tabular-nums'}`}
            >
              {h}
            </th>
          ))
        }
      </tr>
    </thead>
    <tbody>
      {
        rows.map((row) => (
          <tr
            class={`border-b border-slate-100 last:border-0 ${row.best ? 'bg-indigo-50/60' : ''}`}
          >
            {row.cells.map((cell, i) => (
              <td
                class={`px-4 py-3 ${i === 0 ? 'text-slate-900 font-medium' : 'text-right tabular-nums text-slate-700'} ${row.best ? 'font-semibold' : ''}`}
              >
                {row.best && i === 0 && (
                  <span class="text-indigo-600 mr-1.5" aria-label="best">
                    ★
                  </span>
                )}
                {cell}
              </td>
            ))}
          </tr>
        ))
      }
    </tbody>
  </table>
</div>
{caption && (
  <p class="not-prose -mt-3 mb-6 text-sm text-slate-500 text-center">{caption}</p>
)}
