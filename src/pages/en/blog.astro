---
import Layout from '../../layouts/Layout.astro';
import { t } from '../../i18n/ui';

const lang = 'en' as const;
const currentPath = '/en/blog';
---

<Layout lang={lang} title={t(lang, 'blog.title')} currentPath={currentPath}>
  <section class="py-8 md:py-12">
    <h1 class="text-3xl md:text-5xl font-bold text-white mb-4">
      {t(lang, 'blog.title')}
    </h1>
    <p class="text-slate-400 text-lg max-w-3xl mb-10">
      {t(lang, 'blog.subtitle')}
    </p>
    <div class="rounded-lg border border-dashed border-slate-700 bg-slate-900/30 p-10 text-center">
      <p class="text-slate-400">{t(lang, 'blog.empty')}</p>
    </div>
  </section>
</Layout>
