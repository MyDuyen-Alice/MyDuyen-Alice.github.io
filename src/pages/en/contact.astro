---
import Layout from '../../layouts/Layout.astro';
import { t } from '../../i18n/ui';

const lang = 'en' as const;
const currentPath = '/en/contact';

const contacts = [
  {
    label: t(lang, 'contact.email'),
    value: 'vongocminh0609@gmail.com',
    href: 'mailto:vongocminh0609@gmail.com',
  },
  {
    label: t(lang, 'contact.github'),
    value: 'github.com/vongocminh',
    href: 'https://github.com/',
  },
  {
    label: t(lang, 'contact.linkedin'),
    value: 'linkedin.com/in/vongocminh',
    href: 'https://www.linkedin.com/',
  },
];
---

<Layout lang={lang} title={t(lang, 'contact.title')} currentPath={currentPath}>
  <section class="py-8 md:py-12">
    <h1 class="text-3xl md:text-5xl font-bold text-white mb-4">
      {t(lang, 'contact.title')}
    </h1>
    <p class="text-slate-400 text-lg max-w-2xl mb-10">
      {t(lang, 'contact.subtitle')}
    </p>
    <ul class="space-y-3 max-w-xl">
      {
        contacts.map((c) => (
          <li>
            <a
              href={c.href}
              class="flex items-center justify-between rounded-lg border border-slate-800 bg-slate-900/50 px-5 py-4 hover:border-emerald-500/40 transition-colors group"
              target={c.href.startsWith('http') ? '_blank' : undefined}
              rel={c.href.startsWith('http') ? 'noopener' : undefined}
            >
              <div>
                <p class="text-xs uppercase tracking-wider text-slate-500">
                  {c.label}
                </p>
                <p class="text-slate-100 group-hover:text-emerald-400 transition-colors">
                  {c.value}
                </p>
              </div>
              <span class="text-slate-500 group-hover:text-emerald-400 transition-colors">
                →
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</Layout>
