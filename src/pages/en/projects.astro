---
import Layout from '../../layouts/Layout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { t } from '../../i18n/ui';
import { projects } from '../../data/projects';

const lang = 'en' as const;
const currentPath = '/en/projects';
---

<Layout lang={lang} title={t(lang, 'projects.title')} currentPath={currentPath}>
  <section class="py-8 md:py-12">
    <h1 class="text-3xl md:text-5xl font-bold text-white mb-4">
      {t(lang, 'projects.title')}
    </h1>
    <p class="text-slate-400 text-lg max-w-3xl mb-10">
      {t(lang, 'projects.subtitle')}
    </p>
    <div class="grid gap-5 md:grid-cols-2">
      {projects.map((p) => <ProjectCard project={p} lang={lang} />)}
    </div>
  </section>
</Layout>
