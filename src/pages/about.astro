---
import Layout from '../layouts/Layout.astro';
import { t } from '../i18n/ui';
import { skills, timeline } from '../data/projects';

const lang = 'vi' as const;
const currentPath = '/about';
---

<Layout lang={lang} title={t(lang, 'nav.about')} currentPath={currentPath}>
  <section class="py-8 md:py-12">
    <h1 class="text-3xl md:text-5xl font-bold text-slate-900 mb-6">
      {t(lang, 'about.title')}
    </h1>
    <p class="text-slate-700 text-lg leading-relaxed max-w-3xl mb-6">
      {t(lang, 'about.intro')}
    </p>
    <div class="max-w-3xl text-slate-600 leading-relaxed">
      <p>
        Tôi không xuất thân từ ngành CNTT, nhưng tôi luôn bị cuốn hút bởi cách
        dữ liệu định hình quyết định trong kinh doanh. Năm 2026, tôi quyết định
        chuyển sang Data Analytics — vì tôi thích việc tìm ra insight ẩn trong
        dữ liệu và kể chúng lại bằng dashboard để giúp doanh nghiệp ra quyết
        định tốt hơn.
      </p>
      <p class="mt-4">
        Tôi học bằng cách <strong class="text-slate-900">làm thật</strong>,
        không chỉ đọc. Portfolio này là các dự án phân tích tôi tự tay làm: từ
        truy vấn SQL, làm sạch dữ liệu, tới xây dashboard Power BI và rút ra
        khuyến nghị hành động cho business.
      </p>
    </div>
  </section>

  <section class="py-8 border-t border-slate-200">
    <h2 class="text-2xl font-bold text-slate-900 mb-6">
      {t(lang, 'about.skills.title')}
    </h2>
    <div class="grid gap-4 md:grid-cols-2">
      {
        Object.entries(skills).map(([category, items]) => (
          <div class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
            <h3 class="text-indigo-600 text-sm uppercase tracking-wider mb-3 font-medium">
              {category}
            </h3>
            <ul class="flex flex-wrap gap-2">
              {items.map((item) => (
                <li class="text-sm px-2 py-1 rounded bg-slate-100 text-slate-700">
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>

  <section class="py-8 border-t border-slate-200">
    <h2 class="text-2xl font-bold text-slate-900 mb-6">
      {t(lang, 'about.timeline.title')}
    </h2>
    <ol class="relative border-l-2 border-slate-200 ml-3 space-y-6">
      {
        timeline.map((entry) => (
          <li class="ml-6">
            <span class="absolute -left-[7px] w-3 h-3 bg-indigo-500 rounded-full ring-4 ring-white" />
            <time class="text-sm text-slate-500">{entry.date}</time>
            <p class="text-slate-700 mt-1">{entry.vi}</p>
          </li>
        ))
      }
    </ol>
  </section>
</Layout>
